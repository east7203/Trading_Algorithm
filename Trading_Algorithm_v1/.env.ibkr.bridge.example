# IBKR TWS / IB Gateway bridge settings
IBKR_BRIDGE_ENABLED=false
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=17001

# Supported source symbols: NQ,YM,MNQ,MYM (aliases can be remapped below)
IBKR_BRIDGE_SYMBOLS=NQ,YM
IBKR_BRIDGE_SYMBOL_MAP={"NQ":"NQ","YM":"YM"}

# Override default futures contract specs only when needed.
# Defaults:
# NQ -> CME multiplier 20
# YM -> CBOT multiplier 5
# MNQ -> CME multiplier 2
# MYM -> CBOT multiplier 0.5
IBKR_CONTRACT_SPECS_JSON={"NQ":{"symbol":"NQ","exchange":"CME","currency":"USD","multiplier":"20"},"YM":{"symbol":"YM","exchange":"CBOT","currency":"USD","multiplier":"5"}}

# Live bar subscription uses reqHistoricalData(... keepUpToDate=true)
# Values below intentionally include spaces because IBKR expects the native duration/bar-size strings.
# The bridge reads this file directly; do not shell-source it.
IBKR_LIVE_INITIAL_DURATION=1800 S
IBKR_BAR_SIZE=1 min
IBKR_WHAT_TO_SHOW=TRADES
IBKR_USE_RTH=false
IBKR_MAX_BARS_PER_INGEST=400
IBKR_STATUS_SECONDS=60
IBKR_RECONNECT_MIN_MS=1000
IBKR_RECONNECT_MAX_MS=60000
IBKR_STARTUP_READY_TIMEOUT_SECONDS=90
IBKR_CONTRACT_LOOKUP_RETRIES=6
IBKR_CONTRACT_LOOKUP_RETRY_SLEEP_SECONDS=10

# Runtime/python
IBKR_PYTHON_BIN=python3

# Local API server target
TRAINING_API_BASE_URL=http://127.0.0.1:3000
TRAINING_API_KEY=
TRAINING_API_KEY_HEADER=x-api-key
