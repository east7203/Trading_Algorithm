TRADOVATE_BRIDGE_ENABLED=true
TRADOVATE_API_URL=https://demo.tradovateapi.com/v1
TRADOVATE_MD_WS_URL=wss://md.tradovateapi.com/v1/websocket
TRADOVATE_USERNAME=your_tradovate_username
TRADOVATE_PASSWORD=your_tradovate_password
# Optional API app credentials (if required by your account):
# TRADOVATE_APP_ID=your_app_id
# TRADOVATE_APP_VERSION=1.0
# TRADOVATE_CID=1234
# TRADOVATE_SEC=your_sec
TRADOVATE_BRIDGE_SYMBOLS=NQM6,ESM6
# Optional override map from contract symbols to internal symbols:
# TRADOVATE_SYMBOL_MAP={"NQM6":"NQ","ESM6":"ES"}
TRADOVATE_CHART_HISTORY_BARS=300
TRAINING_API_BASE_URL=http://127.0.0.1:3000
# Optional API auth for your training server:
# TRAINING_API_KEY=
# TRAINING_API_KEY_HEADER=x-api-key
