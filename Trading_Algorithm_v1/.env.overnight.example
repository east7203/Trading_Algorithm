# Overnight Polygon fetch + training job
POLYGON_OVERNIGHT_TICKERS=QQQ,SPY
POLYGON_OVERNIGHT_SYMBOL_MAP={"QQQ":"NQ","SPY":"ES"}
POLYGON_OVERNIGHT_START=2024-01-01
# optional; defaults to today's date
# POLYGON_OVERNIGHT_END=2026-03-10
POLYGON_OVERNIGHT_OUTPUT_ROOT=data/historical/polygon-overnight
POLYGON_OVERNIGHT_REQUEST_DELAY_MS=1500
POLYGON_OVERNIGHT_RETRIES=30
POLYGON_OVERNIGHT_VALIDATION_PCT=20
POLYGON_OVERNIGHT_STEP=1
POLYGON_OVERNIGHT_LOOKBACK_1M=240
POLYGON_OVERNIGHT_LOOKAHEAD_1M=120
POLYGON_OVERNIGHT_MODEL_OUTPUT=data/models/latest-ranking-model.json
