# Free Yahoo chart bridge (delayed market data, no API key)
YAHOO_BRIDGE_ENABLED=true
YAHOO_BRIDGE_SYMBOLS=NQ=F,ES=F
YAHOO_BRIDGE_SYMBOL_MAP={"NQ=F":"NQ","ES=F":"ES"}
YAHOO_INTERVAL=1m
YAHOO_RANGE=1d
YAHOO_POLL_SECONDS=60
YAHOO_OVERLAP_SECONDS=90
YAHOO_MAX_BARS_PER_INGEST=400
YAHOO_BASE_URL=https://query2.finance.yahoo.com
YAHOO_USER_AGENT=Mozilla/5.0
YAHOO_REQUEST_RETRIES=3
YAHOO_FORCE_CURL=false
TRAINING_API_BASE_URL=http://127.0.0.1:3000
