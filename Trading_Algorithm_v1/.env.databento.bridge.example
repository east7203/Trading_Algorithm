DATABENTO_BRIDGE_ENABLED=true
DATABENTO_API_KEY=your_databento_api_key
DATABENTO_BASE_URL=https://hist.databento.com/v0
DATABENTO_DATASET=GLBX.MDP3
DATABENTO_SCHEMA=ohlcv-1m
# Typical options: raw_symbol | parent | continuous
DATABENTO_STYPE_IN=continuous
# Examples: NQ.c.0,ES.c.0  or NQ.FUT,ES.FUT (depending on symbology plan)
DATABENTO_BRIDGE_SYMBOLS=NQ.c.0,ES.c.0
# Optional override map to internal symbols:
# DATABENTO_SYMBOL_MAP={"NQ.C.0":"NQ","ES.C.0":"ES"}
DATABENTO_POLL_SECONDS=60
DATABENTO_INITIAL_LOOKBACK_MINUTES=180
DATABENTO_OVERLAP_SECONDS=90
DATABENTO_MAX_BARS_PER_INGEST=400
TRAINING_API_BASE_URL=http://127.0.0.1:3000
# Optional API auth for training server:
# TRAINING_API_KEY=
# TRAINING_API_KEY_HEADER=x-api-key
