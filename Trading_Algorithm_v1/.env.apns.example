NATIVE_PUSH_ENABLED=true
APNS_TEAM_ID=YOUR_APPLE_TEAM_ID
APNS_KEY_ID=YOUR_APNS_KEY_ID
APNS_BUNDLE_ID=com.tradingalgo.mobile
APNS_USE_SANDBOX=true
APNS_PRIVATE_KEY_PATH=/opt/trading-algorithm/secrets/AuthKey_XXXXXXXXXX.p8
# Alternative to APNS_PRIVATE_KEY_PATH:
# APNS_PRIVATE_KEY_BASE64=BASE64_ENCODED_P8_CONTENT
